<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0f1117">

    <!-- Loading state -->
    <LinearLayout
        android:id="@+id/loadingView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible">

        <ProgressBar
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:indeterminateTint="#ff5252"
            android:layout_marginBottom="16dp"/>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Analyzing session…"
            android:textColor="#7a7d92"
            android:textSize="15sp"/>
    </LinearLayout>

    <!-- Content (shown after analysis) -->
    <ScrollView
        android:id="@+id/contentScroll"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Session title -->
            <TextView
                android:id="@+id/sessionTitleText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#e8eaf0"
                android:textSize="22sp"
                android:textStyle="bold"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="4dp"/>

            <TextView
                android:id="@+id/sessionDateText"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:textColor="#7a7d92"
                android:textSize="13sp"
                android:layout_marginBottom="24dp"/>

            <!-- Session summary card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SESSION SUMMARY"
                    android:textColor="#7a7d92"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="14dp"/>

                <TextView
                    android:id="@+id/durationText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#e8eaf0"
                    android:textSize="15sp"
                    android:layout_marginBottom="6dp"/>

                <TextView
                    android:id="@+id/workoutRestText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#aaaaaa"
                    android:textSize="14sp"
                    android:layout_marginBottom="14dp"/>

                <TextView
                    android:id="@+id/avgHrText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#ff5252"
                    android:textSize="17sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/peakHrText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#ff8a80"
                    android:textSize="15sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/restingHrText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:textColor="#aaaaaa"
                    android:textSize="14sp"/>
            </LinearLayout>

            <!-- Zone breakdown card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_marginBottom="12dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="TIME IN ZONE"
                    android:textColor="#7a7d92"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="12dp"/>

                <LinearLayout
                    android:id="@+id/zoneContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>

            <!-- Segments card -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_bg"
                android:orientation="vertical"
                android:padding="18dp"
                android:layout_marginBottom="20dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PERIOD BREAKDOWN"
                    android:textColor="#7a7d92"
                    android:textSize="10sp"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="4dp"/>

                <LinearLayout
                    android:id="@+id/segmentContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"/>
            </LinearLayout>

            <!-- Export buttons -->
            <Button
                android:id="@+id/shareReportBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Share / Export HTML Report"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/shareCsvBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Share / Export Raw CSV"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:textColor="#ff5252"
                android:layout_marginBottom="10dp"/>

            <Button
                android:id="@+id/doneBtn"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:text="Done"
                android:backgroundTint="#1a1d2e"
                android:textColor="#7a7d92"
                android:layout_marginBottom="20dp"/>

        </LinearLayout>
    </ScrollView>

</FrameLayout>
